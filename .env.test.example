# Copy this to .env.test and fill in real values. .env* is gitignored.
#
# Codex authenticates TWO ways — the e2e suite supports both:
#
#   1. OpenAI API key — set OPENAI_API_KEY below.
#   2. ChatGPT Plus/Pro/Team subscription — leave OPENAI_API_KEY blank and
#      point CODEXBOX_DATA_DIR at a ~/.codex that already has a `codex login`
#      (the suite mounts it). Do the login once with:
#        docker run -it -v "$HOME/.codex:/home/aicode/.codex" \
#          psyb0t/codexbox:latest login --device-auth
OPENAI_API_KEY=

# Subscription auth: host codex dir to mount (holds auth.json from `codex login`).
# Only used when OPENAI_API_KEY is blank. Default: ~/.codex
CODEXBOX_DATA_DIR=

# Optional — point at an OpenAI-compatible endpoint instead of api.openai.com.
OPENAI_BASE_URL=

# Model for tests — use a SMALL/cheap one, not the flagship.
#   ChatGPT subscription models (GPT-5.6 family): gpt-5.6-luna (fast+cheapest),
#     gpt-5.6-terra (balanced), gpt-5.6-sol (flagship — the account default).
#   API-key models: gpt-5.1-codex-mini (small), gpt-5.1-codex, gpt-5-codex.
# NOTE: the *-codex / *-codex-mini slugs are API-key ONLY — a ChatGPT account
# rejects them with 400. Subscription accounts must use a gpt-5.6-* slug.
CODEXBOX_MODEL=gpt-5.6-luna

# Telegram e2e tests (test_telegram.sh, test_cron_telegram.sh, test_e2e_telegram.sh).
# Leave blank to skip those tests.
AICODEBOX_TELEGRAM_MODE_TOKEN=
TELEGRAM_CHAT_ID=

# Telethon userbot — drives the user side of the Telegram e2e tests.
# Get API_ID / API_HASH from https://my.telegram.org/apps.
# Get TELETHON_SESSION from psyb0t/docker-telethon (make login).
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
TELETHON_AUTH_KEY=
